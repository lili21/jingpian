# App URL
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000

# Better Auth
BETTER_AUTH_URL=http://127.0.0.1:3000
BETTER_AUTH_SECRET=replace-with-a-long-random-string
BETTER_AUTH_DB_PATH=./data/auth.db

# Storyboard generation via AI SDK + OpenAI-compatible provider
# Default this to OpenRouter, or point it at another OpenAI-compatible endpoint.
AI_COMPATIBLE_BASE_URL=https://openrouter.ai/api/v1
AI_COMPATIBLE_API_KEY=
STORYBOARD_MODEL=openai/gpt-4.1-mini

# Vercel AI Gateway image generation (preferred when configured)
AI_GATEWAY_API_KEY=
AI_GATEWAY_IMAGE_MODEL=openai/gpt-image-1
AI_GATEWAY_VIDEO_MODEL=bytedance/seedance-2.0

# Direct OpenRouter image/video fallback
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_IMAGE_MODEL=openai/gpt-5.4-image-2
OPENROUTER_VIDEO_MODEL=bytedance/seedance-2.0

# Optional OpenRouter app identity headers
OPENROUTER_SITE_URL=http://127.0.0.1:3000
OPENROUTER_SITE_NAME=Jingpian

# Stripe billing (optional; unauthenticated or unconfigured flows degrade gracefully)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PREMIUM_PRICE_ID=
